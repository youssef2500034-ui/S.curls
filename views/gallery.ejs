<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('Components/head', { title: 'Gallery - S.curls Studio' }) %>
</head>
<body>
  <!-- Header -->
  <%- include('Components/header', { active: 'gallery' }) %>

  <!-- Gallery Hero -->
  <section class="page-hero gallery-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Our work</p>
        <h1>Gallery of curls & shine</h1>
        <p class="lead">Recent sets, cuts, and transformations from Rehab and Sheikh Zayed.</p>
        <div class="hero-actions">
          <a href="booking.html" class="btn">Book this style</a>
          <a href="#gallery-grid" class="btn ghost">Browse looks</a>
        </div>
        <p class="mini-note">Updated weekly · Real guests · No stock retouching</p>
      </div>
      <div class="hero-metrics">
        <div class="metric-card">
          <p class="label">Styles captured</p>
          <p class="value">128</p>
          <p class="hint">Across both branches</p>
        </div>
        <div class="metric-card">
          <p class="label">Average rating</p>
          <p class="value">4.9</p>
          <p class="hint">From booked sessions</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="gallery-section" id="gallery-grid">
    <div class="container">
      <div class="filter-bar" aria-label="Filter gallery">
        <button class="filter-pill is-active" data-filter="all">All</button>
        <button class="filter-pill" data-filter="cuts">Cuts</button>
        <button class="filter-pill" data-filter="color">Color</button>
        <button class="filter-pill" data-filter="styling">Styling</button>
        <button class="filter-pill" data-filter="bridal">Bridal</button>
        <button class="filter-pill" data-filter="favs">Favorites</button>
        <span class="filter-meta" id="filter-count">8 looks</span>
      </div>

      <div class="gallery-grid">
        <!-- Dynamic gallery cards should be rendered here -->
      </div>
    </div>
  </section>

  <!-- Footer -->
  <%- include('Components/footer') %>
  <script src="api-client.js"></script>
  <script src="gallery.js"></script>
</body>
</html>
