<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('Components/head', { title: 'Shop - S.curls Studio' }) %>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <%- include('Components/header', { active: 'shop' }) %>
  <section class="shop-hero">
    <div class="container">
      <h1>Shop Products</h1>
      <p class="lead">Browse our curated hair care products and accessories.</p>
    </div>
  </section>
  <section class="shop-grid-section">
    <div class="container">
      <div class="shop-grid" id="shop-grid"></div>
      <aside class="cart-sidebar" id="cart-sidebar">
        <h2>Your Cart</h2>
        <ul id="cart-items"></ul>
        <div class="cart-summary">
          <span id="cart-subtotal">Subtotal: $0</span>
          <button id="checkout-btn" class="primary-btn">Checkout</button>
        </div>
      </aside>
    </div>
  </section>
  <%- include('Components/footer') %>
  <script src="shop.js"></script>
</body>
</html>
