<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('Components/head', { title: 'Testimonials - S.curls Studio' }) %>
</head>
<body>
  <!-- Header -->
  <%- include('Components/header', { active: 'testimonials' }) %>

  <!-- Testimonials Section -->
  <section class="testimonials">
    <h1>Customer Reviews</h1>
    <p class="section-lead">Real words from guests who trust us with their curls.</p>

    <div class="testimonial-form card">
      <h2>Rate your last visit</h2>
      <p class="hint">You’ll need to submit a rating to book again. We’ll match it to your latest visit on this mobile.</p>
      <form id="rating-form" class="rating-form">
        <label>Mobile (11 digits)
          <input type="tel" id="rating-mobile" required placeholder="01012345678">
        </label>
        <label>Stylist (optional)
          <input type="text" id="rating-stylist" placeholder="Stylist name">
        </label>
        <label>Rating
          <select id="rating-score" required>
            <option value="">Select</option>
            <option value="5">5 - Loved it</option>
            <option value="4">4 - Great</option>
            <option value="3">3 - Good</option>
            <option value="2">2 - Could be better</option>
            <option value="1">1 - Not happy</option>
          </select>
        </label>
        <label>Comments (optional)
          <textarea id="rating-comment" rows="3" placeholder="Tell us about your visit"></textarea>
        </label>
        <button type="submit" class="primary-btn" id="rating-submit">Submit rating</button>
        <p class="form-note" id="rating-status"></p>
      </form>
    </div>

    <div class="testimonials-container" id="testimonials-container">
      <div class="testimonial-card skeleton">
        <div class="stars">★★★★★</div>
        <p class="testimonial-text">Loading testimonials...</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <%- include('Components/footer') %>
  <script src="testimonials.js"></script>
</body>
</html>
